# Private key of the deployer/owner wallet (never commit the real .env file)
DEPLOYER_PRIVATE_KEY=

# Robinhood Chain — confirmed from https://docs.robinhood.com/chain/connecting/
# Public RPCs are rate-limited; use a provider (Alchemy recommended) for production.
ROBINHOOD_RPC_URL=https://rpc.mainnet.chain.robinhood.com
ROBINHOOD_TESTNET_RPC_URL=https://rpc.testnet.chain.robinhood.com
ROBINHOOD_EXPLORER_API_KEY=

# WETH on Robinhood Chain (from https://docs.robinhood.com/chain/protocol-contracts/):
#   Mainnet (L2 Weth): 0x0Bd7D308f8E1639FAb988df18A8011f41EAcAD73
#   Testnet (L2 Weth):  0x7943e237c7F95DA44E0301572D358911207852Fa
WETH_ADDRESS=

# Your internal reward token address (deploy separately, then paste it here)
REWARDS_TOKEN_ADDRESS=
