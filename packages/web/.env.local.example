# Get a free project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Robinhood Chain — confirmed from https://docs.robinhood.com/chain/connecting/
# Public RPCs are rate-limited; use a provider (Alchemy recommended) for production.
NEXT_PUBLIC_ROBINHOOD_RPC_URL=https://rpc.mainnet.chain.robinhood.com
NEXT_PUBLIC_ROBINHOOD_TESTNET_RPC_URL=https://rpc.testnet.chain.robinhood.com

# WETH on Robinhood Chain (from https://docs.robinhood.com/chain/protocol-contracts/):
#   Mainnet (L2 Weth): 0x0Bd7D308f8E1639FAb988df18A8011f41EAcAD73
#   Testnet (L2 Weth):  0x7943e237c7F95DA44E0301572D358911207852Fa
NEXT_PUBLIC_WETH_ADDRESS=

# Deployed contract addresses (filled in after running packages/contracts deploy script)
NEXT_PUBLIC_STAKING_ADDRESS=
NEXT_PUBLIC_REWARD_TOKEN_ADDRESS=
